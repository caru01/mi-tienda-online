# ================================================================
# VARIABLES DE ENTORNO - DISTRITO BURGER BOT
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a GitHub
# ================================================================

# --- YCloud API ---
# Tu API Key del panel de YCloud (https://app.ycloud.com)
YCLOUD_API_KEY=tu_api_key_aqui

# Número de WhatsApp Business en formato E.164 (con código de país)
# Ejemplo para Colombia: +573001234567
YCLOUD_PHONE_NUMBER=+573001234567

# --- Supabase ---
# URL de tu proyecto Supabase (https://app.supabase.com → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key (NO la anon key) para saltarse Row Level Security
SUPABASE_KEY=tu_service_role_key_aqui

# --- Configuración del Bot ---
# Zona horaria del negocio
TIMEZONE=America/Bogota

# Horario de apertura (formato HH:MM en 24h)
BUSINESS_OPEN_HOUR=18
BUSINESS_OPEN_MINUTE=0

# Horario de cierre (formato HH en 24h)
BUSINESS_CLOSE_HOUR=22
BUSINESS_CLOSE_MINUTE=0

# Días hábiles (0=Lunes, 1=Martes, ..., 6=Domingo)
# Miércoles a Domingo = 2,3,4,5,6
BUSINESS_DAYS=2,3,4,5,6

# Minutos sin respuesta antes de enviar mensaje de cortesía
BACKUP_REPLY_MINUTES=3

# Token secreto para validar que las peticiones vienen de YCloud (opcional pero recomendado)
WEBHOOK_SECRET=un_token_secreto_que_tu_elijas
